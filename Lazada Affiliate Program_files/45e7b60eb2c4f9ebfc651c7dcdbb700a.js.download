    np: 'https://lzd-img-global.slatic.net/us/media/fe469b86da70f459e1e1538d0bace834-225-150.svg',
  };

  function getSearch() {
    return window.location.search
      .slice(1)
      .split('&')
      .reduce(function (prev, next) {
        var arr = next.split('=');
        var key = arr[0];
        var value = arr[1];
        prev[key] = value;
        return prev;
      }, {});
  }

  // 国家默认sg
  var curCountry =
    Object.keys(domain).find(function (n) {
      return (
        window.location.host.indexOf(domain[n]) >= 0 &&
        window.location.host.indexOf(domain[n]) + domain[n].length === window.location.host.length
      );
    }) ||
    (getSearch() && getSearch().venture && getSearch().venture.toLowerCase()) ||
    Object.keys(domain).find(function (n) {
      return window.location.host.split('.').find(function (h) {
        return h === n || h === 'pre-' + n;
      });
    }) ||
    (window.location.host.indexOf('daraz') >= 0 ? 'pk' : 'sg');

  // 业务域默认lazada
  var curBusiness = lazadaCountry.includes(curCountry)
    ? 'lazada'
    : darazCountry.includes(curCountry)
    ? 'daraz'
    : 'lazada';

  window.getBusConfig = function (business, country) {
    return {
      lazada: {
        logKey: '/affiliate.adsense.pc',
        itrace: 'jtkjl9jz-5f8ixe9c',
        cdn: 'g.lazcdn.com',
        imgCdn: 'lzd-img-global.slatic.net',
        domainWithBusiness: domainWithBusiness[country],
        name: country,
        domain: domain[country],
        business: business,
        memberDomain: `member${domainWithBusiness[country]}`,
        affiliatePath: `//www${domainWithBusiness[country]}/affiliate`,
        sellerCenterPath: `//sellercenter${domainWithBusiness[country]}`,
        written: written[country],
        countryEmail: countryEmail[country],
        countryWritten: countryWritten[country],
        circleFlag: circleFlag[country],
        flag: flag[country],
        busCountry: lazadaCountry,
        nameLower: country.toLowerCase(),
        nameUpper: country.toUpperCase(),
        appItrace: 'affiliate-individual-app',
        protocol: 'lazada:',
      },
      daraz: {
        logKey: '/daraz.affiliate.adsense.pc',
        itrace: '2eln48y1-hm0eokh4',
        cdn: 'g.lazcdn.com',
        imgCdn: 'lzd-img-global.slatic.net',
        domainWithBusiness: domainWithBusiness[country],
        name: country,
        domain: domain[country],
        business: business,
        memberDomain: `member${domainWithBusiness[country]}`,
        affiliatePath: `//www${domainWithBusiness[country]}/affiliate`,
        sellerCenterPath: `//sellercenter${domainWithBusiness[country]}`,
        written: written[country],
        countryEmail: countryEmail[country],
        countryWritten: countryWritten[country],
        circleFlag: circleFlag[country],
        flag: flag[country],
        busCountry: darazCountry,
        nameLower: country.toLowerCase(),
        nameUpper: country.toUpperCase(),
        appItrace: 'daraz-affiliate-individual-app',
        protocol: 'daraz:',
      },
    }[business];
  };

  window.__bus_config__ = window.getBusConfig(curBusiness, curCountry);
})();
