    my: 'Malaysia', // 马来
    th: 'Thailand', // 泰国
    vn: 'Vietnam', // 越南
    id: 'Indonesia', // 印度尼西亚
    ph: 'Philippines', // 菲律宾
    mm: 'Myanmar', // 缅甸
    pk: 'Pakistan', // 巴基斯坦
    bd: 'Bangladesh', // 孟加拉国
